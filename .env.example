# Gmail Configuration
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Notion Configuration
NOTION_API_KEY=secret_your-notion-api-key
NOTION_DATABASE_ID=your-database-id-without-hyphens

# Optional: OpenAI for better task extraction (leave empty to use rule-based extraction)
OPENAI_API_KEY=sk-your-openai-key

# Email Check Settings
EMAIL_CHECK_LIMIT=10
EXTRACT_UNREAD_ONLY=true

# Logging
LOG_LEVEL=INFO
